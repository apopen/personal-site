---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostPreview from '../components/PostPreview.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../lib/config';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <div class="hero-background">
      <div class="gradient-orb orb-1"></div>
      <div class="gradient-orb orb-2"></div>
    </div>
    <div class="hero-content">
      <div class="hero-text-content">
        <h1 class="hero-title animate-fade-in-up">Hello, I'm <span class="gradient-text">{siteConfig.author.name}</span></h1>
        <p class="hero-text animate-fade-in-up" style="animation-delay: 0.1s">
          A technology leader passionate about delivering innovative, scalable software solutions and leading high-performing teams.
        </p>
        <div class="hero-links animate-fade-in-up" style="animation-delay: 0.2s">
          <a href="/blog" class="btn btn-primary">Read my writing <span class="arrow">→</span></a>
          <a href="/about" class="btn btn-secondary">Learn more</a>
        </div>
      </div>
      <div class="hero-visual animate-fade-in" style="animation-delay: 0.3s">
        <div class="image-frame">
          <img 
            src="/1738955362732.jpg" 
            alt="Paul Brohman"
            class="hero-image"
          />
          <div class="image-glow"></div>
        </div>
      </div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="recent-posts">
      <div class="section-header">
        <h2 class="section-title">Recent Writing</h2>
        <a href="/blog" class="view-all">View all posts</a>
      </div>
      <div class="posts-list">
        {posts.map((post, index) => (
          <div class="post-item" style={`animation-delay: ${index * 0.1}s`}>
            <PostPreview post={post} />
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 4rem 1.5rem;
    position: relative;
    overflow: hidden;
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
    top: -100px;
    right: -100px;
    animation: float 8s ease-in-out infinite;
  }

  .orb-2 {
    width: 300px;
    height: 300px;
    background: linear-gradient(135deg, var(--gradient-end), var(--gradient-start));
    bottom: -50px;
    left: -50px;
    animation: float 10s ease-in-out infinite reverse;
  }

  .hero-content {
    max-width: var(--spacing-container);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-text-content {
    max-width: 540px;
  }

  .hero-title {
    font-size: 3.5rem;
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }

  .hero-text {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
    color: white;
    box-shadow: 0 4px 14px rgba(102, 126, 234, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    text-decoration: none;
  }

  .btn-secondary {
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .arrow {
    transition: transform 0.2s ease;
  }

  .btn-primary:hover .arrow {
    transform: translateX(4px);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .image-frame {
    position: relative;
    width: 320px;
    height: 320px;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 24px;
    position: relative;
    filter: grayscale(100%);
    transition: filter 0.3s ease;
    border: 2px solid var(--border);
  }

  .hero-image:hover {
    filter: grayscale(80%);
  }

  .image-glow {
    position: absolute;
    inset: -20px;
    background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
    border-radius: 32px;
    opacity: 0.2;
    filter: blur(30px);
    animation: pulse 4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(1.02); }
  }

  .recent-posts {
    padding: 2rem 1.5rem 4rem;
    max-width: var(--spacing-content);
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .section-title {
    font-size: 1.25rem;
    margin: 0;
    font-family: "Satoshi", sans-serif;
    font-weight: 500;
  }

  .view-all {
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .view-all:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    opacity: 0;
    animation: fadeInUp 0.5s ease forwards;
  }

  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-text-content {
      max-width: none;
    }

    .hero-links {
      justify-content: center;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .image-frame {
      width: 260px;
      height: 260px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3rem 1rem;
      min-height: auto;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-text {
      font-size: 1rem;
    }

    .hero-links {
      flex-direction: column;
    }

    .btn {
      justify-content: center;
    }
  }
</style>
