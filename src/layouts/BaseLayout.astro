---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../lib/config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  articlePublishedTime?: string;
  articleAuthor?: string[];
  articleTags?: string[];
}

const { 
  title, 
  description, 
  image, 
  type,
  articlePublishedTime,
  articleAuthor,
  articleTags
} = Astro.props;

const currentPath = Astro.url.pathname;

const socialLinks = [
  siteConfig.author.linkedin ? `https://ca.linkedin.com/in/${siteConfig.author.linkedin}` : null,
  siteConfig.author.github ? `https://github.com/${siteConfig.author.github}` : null,
  siteConfig.author.twitter ? `https://twitter.com/${siteConfig.author.twitter.replace('@', '')}` : null
].filter(Boolean);

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": siteConfig.author.name,
  "url": siteConfig.siteUrl,
  "jobTitle": "Technology Leader",
  "sameAs": socialLinks
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead 
      title={title} 
      description={description} 
      image={image} 
      type={type}
      articlePublishedTime={articlePublishedTime}
      articleAuthor={articleAuthor}
      articleTags={articleTags}
    />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <Navigation currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline defer src="/_vercel/speed-insights/script.js"></script>
    <script is:inline defer src="/_vercel/insights/script.js"></script>
  </body>
</html>

<style>
  main {
    flex: 1;
    width: 100%;
  }
</style>
