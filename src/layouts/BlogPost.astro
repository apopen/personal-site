---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { siteConfig } from '../lib/config';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout 
  title={title} 
  description={description} 
  type="article"
  articlePublishedTime={pubDate.toISOString()}
  articleAuthor={[siteConfig.author.name]}
  articleTags={tags}
>
  <article class="post">
    <div class="post-header animate-fade-in-up">
      <a href="/blog" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Back to blog
      </a>
      <div class="author-info">
        <img 
          src="/1738955362732.jpg" 
          alt={siteConfig.author.name}
          class="author-avatar"
        />
        <div class="author-details">
          <span class="author-name">{siteConfig.author.name}</span>
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        </div>
      </div>
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        {updatedDate && (
          <span class="updated">
            (Updated: {formatDate(updatedDate)})
          </span>
        )}
      </div>
    </div>
    <div class="post-content animate-fade-in" style="animation-delay: 0.2s">
      <slot />
    </div>
    {tags.length > 0 && (
      <div class="post-tags animate-fade-in-up" style="animation-delay: 0.3s">
        {tags.map(tag => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .post {
    padding: 3rem 1.5rem;
  }

  .post-header {
    max-width: var(--spacing-content);
    margin: 0 auto 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: none;
    margin-bottom: 1.5rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
    background: rgba(102, 126, 234, 0.1);
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    filter: grayscale(100%);
  }

  .author-details {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .author-name {
    font-weight: 500;
    color: var(--text);
  }

  .author-details time {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .post-title {
    font-size: 3rem;
    margin-bottom: 0.75rem;
    line-height: 1.1;
    background: linear-gradient(135deg, var(--text), var(--text-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-meta {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .updated {
    color: var(--text-secondary);
    opacity: 0.7;
  }

  .post-content {
    max-width: var(--spacing-content);
    margin: 0 auto;
  }

  .post-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.75rem;
  }

  .post-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.375rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .post-content :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-content :global(ul li),
  .post-content :global(ol li) {
    margin-bottom: 0.75rem;
    line-height: 1.7;
    list-style-type: disc;
  }

  .post-content :global(ol li) {
    list-style-type: decimal;
  }

  .post-content :global(a) {
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .post-content :global(a:hover) {
    color: var(--accent);
  }

  .post-content :global(img) {
    width: 100%;
    margin: 2rem 0;
    border-radius: 12px;
  }

  .post-content :global(blockquote) {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-left: 4px solid;
    border-image: linear-gradient(to bottom, var(--gradient-start), var(--gradient-end)) 1;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
    border-radius: 0 8px 8px 0;
  }

  .post-content :global(code) {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
    border-color: transparent;
  }

  .post-tags {
    max-width: var(--spacing-content);
    margin: 3rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag {
    font-size: 0.875rem;
    color: var(--text-secondary);
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
    padding: 0.375rem 0.875rem;
    border-radius: 20px;
    border: 1px solid transparent;
    transition: all 0.2s ease;
  }

  .tag:hover {
    border-color: var(--accent);
    transform: scale(1.02);
  }

  @media (max-width: 640px) {
    .post {
      padding: 2rem 1rem;
    }

    .post-title {
      font-size: 2rem;
    }
  }
</style>
